<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.MenuController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="10" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label fx:id="branchLabel" text="Branch Menu"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
            </HBox>

            <!-- Category tabs -->
            <HBox fx:id="categoryBar" spacing="8" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="28" bottom="8" left="28"/>
                </padding>
            </HBox>

            <!-- Drinks sub-tabs (Espresso Hot / Cold / Refreshers) -->
            <HBox fx:id="drinksSubBar" spacing="8" alignment="CENTER_LEFT" managed="false" visible="false"
                   style="-fx-background-color: #f5efe9; -fx-border-color: #efe6df; -fx-border-width: 1 0 0 0;">
                <padding>
                    <Insets top="8" right="28" bottom="12" left="28"/>
                </padding>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #faf7f4; -fx-background-color: #faf7f4;">
            <FlowPane fx:id="menuGrid" hgap="18" vgap="18" alignment="TOP_LEFT"
                      style="-fx-background-color: #faf7f4;">
                <padding>
                    <Insets top="20" right="28" bottom="28" left="28"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
