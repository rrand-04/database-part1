<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.OrderPlacementController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="10" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label text="Place Order"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userLabel" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #faf7f4; -fx-background-color: #faf7f4;">
        <VBox spacing="20" style="-fx-padding: 24 28;">
            <!-- Step A: Branch & order type -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="Step 1 — Branch &amp; order type"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Branch:" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <ComboBox fx:id="branchCombo" prefWidth="280" promptText="Select a branch"
                              onAction="#onBranchSelected"/>
                </HBox>

                <HBox spacing="24" alignment="CENTER_LEFT">
                    <RadioButton fx:id="dineInRadio" text="Dine-In" selected="true"/>
                    <RadioButton fx:id="deliveryRadio" text="Delivery"/>
                </HBox>

                <HBox fx:id="dineInBox" spacing="12" alignment="CENTER_LEFT">
                    <Label text="Table:" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <ComboBox fx:id="tableCombo" prefWidth="220" promptText="Select a table"/>
                </HBox>

                <HBox fx:id="deliveryBox" spacing="12" alignment="CENTER_LEFT" visible="false" managed="false">
                    <Label text="Address:" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <TextField fx:id="deliveryAddressField" promptText="Delivery address" prefWidth="400"/>
                </HBox>

                <Label fx:id="stepAErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>

            <!-- Step B: Browse menu -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="Step 2 — Browse menu &amp; add to cart"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <HBox fx:id="menuCategoryBar" spacing="4" alignment="CENTER_LEFT"
                      style="-fx-border-color: #efe6df; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 8 0;"/>

                <HBox fx:id="menuDrinksSubBar" spacing="6" alignment="CENTER_LEFT"
                      visible="false" managed="false"
                      style="-fx-background-color: #f5efe9; -fx-background-radius: 8; -fx-padding: 6 8;"/>

                <ScrollPane fitToWidth="true" prefHeight="420"
                            style="-fx-background: #faf7f4; -fx-background-color: #faf7f4;">
                    <FlowPane fx:id="menuGrid" hgap="14" vgap="14" alignment="TOP_LEFT"
                              style="-fx-background-color: #faf7f4; -fx-padding: 4;"/>
                </ScrollPane>

                <Label fx:id="stepBErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>

            <!-- Step C: Cart -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="Step 3 — Review cart"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <TableView fx:id="cartTable" prefHeight="160">
                    <columns>
                        <TableColumn fx:id="cartNameColumn" text="Item" prefWidth="220"/>
                        <TableColumn fx:id="cartQtyColumn" text="Qty" prefWidth="60"/>
                        <TableColumn fx:id="cartPriceColumn" text="Unit (₪)" prefWidth="90"/>
                        <TableColumn fx:id="cartSubtotalColumn" text="Subtotal (₪)" prefWidth="110"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="totalLabel" text="Total: ₪ 0.00"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                </HBox>

                <Label fx:id="stepCErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>

            <!-- Step D: Payment -->
            <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="Step 4 — Payment"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Method:" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <ComboBox fx:id="paymentMethodCombo" prefWidth="180" promptText="How will you pay?"
                              onAction="#onPaymentMethodChanged"/>
                </HBox>

                <VBox fx:id="cardDetailsBox" spacing="8" visible="false" managed="false">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Card number:" prefWidth="100" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                        <TextField fx:id="cardNumberField" prefWidth="220" promptText="16 digits, no spaces"/>
                    </HBox>
                    <Label text="Test card for demo: 4111111111111111"
                           style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>
                </VBox>

                <VBox fx:id="walletDetailsBox" spacing="8" visible="false" managed="false">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="Phone:" prefWidth="100" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                        <TextField fx:id="walletPhoneField" prefWidth="180" promptText="e.g. 0591234567"/>
                    </HBox>
                    <Label text="Mobile wallet number linked to your account."
                           style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>
                </VBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Amount (₪):" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <TextField fx:id="paymentAmountField" prefWidth="140" editable="false"
                               style="-fx-background-color: #f5f0eb;"/>
                    <Label text="Matches your order total" style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>
                </HBox>

                <Label text="Payment status is confirmed automatically after you submit."
                       wrapText="true"
                       style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                    <Button fx:id="placeOrderButton" text="Place Order &amp; Pay" onAction="#placeOrder"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="stepDErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>
        </VBox>
        </ScrollPane>
    </center>
</BorderPane>
