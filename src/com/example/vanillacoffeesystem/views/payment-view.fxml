<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.PaymentController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="14" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label text="Payment History"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Status:" style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                <ComboBox fx:id="statusFilterCombo" prefWidth="120" onAction="#filterByStatus"
                          style="-fx-font-size: 13px;"/>
                <Label text="Method:" style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                <ComboBox fx:id="methodFilterCombo" prefWidth="120" onAction="#filterByMethod"
                          style="-fx-font-size: 13px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 28;">
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <TableView fx:id="paymentsTable" prefHeight="360">
                    <columns>
                        <TableColumn fx:id="paymentIdColumn" text="Payment ID" prefWidth="100"/>
                        <TableColumn fx:id="orderIdColumn" text="Order ID" prefWidth="90"/>
                        <TableColumn fx:id="branchColumn" text="Branch" prefWidth="180"/>
                        <TableColumn fx:id="methodColumn" text="Payment Method" prefWidth="140"/>
                        <TableColumn fx:id="amountColumn" text="Amount (₪)" prefWidth="110"/>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                    </columns>
                </TableView>

                <Label fx:id="emptyLabel" text="No payments found."
                       visible="false" managed="false"
                       style="-fx-font-size: 14px; -fx-text-fill: #8d6e63;"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT">
                <Label fx:id="totalPaidLabel" text="Total Paid: ₪ 0.00"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
