<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.ReservationController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="14" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label text="Table Reservations"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" style="-fx-padding: 24 28;">
            <!-- New Reservation -->
            <VBox spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <Label text="New Reservation"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Branch:" prefWidth="80" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <ComboBox fx:id="branchCombo" prefWidth="260" promptText="Select branch"/>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Date:" prefWidth="80" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <DatePicker fx:id="datePicker" prefWidth="160"/>
                    <Label text="Today or later" style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="Time:" prefWidth="80" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <TextField fx:id="timeField" prefWidth="100" promptText="HH:MM"/>
                    <Label text="24-hour format, e.g. 18:30" style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>
                </HBox>

                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="People:" prefWidth="80" style="-fx-font-size: 13px; -fx-text-fill: #5d4037;"/>
                    <Spinner fx:id="peopleSpinner" prefWidth="100" editable="true"/>
                </HBox>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="bookButton" text="Book" onAction="#bookReservation"
                            style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 24; -fx-cursor: hand;"/>
                </HBox>

                <Label fx:id="formErrorLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828;"/>
            </VBox>

            <!-- My Reservations -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #e8ddd4; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="My Reservations"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="cancelButton" text="Cancel Selected" onAction="#cancelReservation"
                            disable="true"
                            style="-fx-background-color: transparent; -fx-text-fill: #c62828; -fx-border-color: #ef9a9a; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6 16; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="reservationsTable" prefHeight="280">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="branchColumn" text="Branch" prefWidth="200"/>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                        <TableColumn fx:id="timeColumn" text="Time" prefWidth="90"/>
                        <TableColumn fx:id="peopleColumn" text="People" prefWidth="80"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="110"/>
                    </columns>
                </TableView>

                <Label fx:id="emptyLabel" text="No reservations yet."
                       visible="false" managed="false"
                       style="-fx-font-size: 14px; -fx-text-fill: #8d6e63;"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
