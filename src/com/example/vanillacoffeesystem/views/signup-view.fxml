<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.vanillacoffeesystem.SignUpController"
           style="-fx-background-color: linear-gradient(to bottom right, #2c1810, #4e342e, #6d4c41);">

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox alignment="CENTER" spacing="0" maxWidth="440"
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 24, 0, 0, 6);">
            <padding>
                <Insets top="32" right="40" bottom="32" left="40"/>
            </padding>

            <Label text="Create Account"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #3e2723;"/>

            <Label text="Join Vanilla Coffee as a customer"
                   style="-fx-font-size: 13px; -fx-text-fill: #8d6e63; -fx-padding: 2 0 20 0;"/>

            <VBox spacing="10" alignment="CENTER_LEFT" prefWidth="320">

                <Label text="Full name" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5d4037;"/>
                <TextField fx:id="nameField" promptText="Your full name"
                           prefWidth="320" prefHeight="42"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d7ccc8; -fx-border-width: 1; -fx-font-size: 14px;"/>

                <Label text="Phone number" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5d4037; -fx-padding: 4 0 0 0;"/>
                <TextField fx:id="contactField" promptText="e.g. 0591234567"
                           prefWidth="320" prefHeight="42"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d7ccc8; -fx-border-width: 1; -fx-font-size: 14px;"/>

                <Label text="Username" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5d4037; -fx-padding: 4 0 0 0;"/>
                <TextField fx:id="usernameField" promptText="e.g. lina_coffee"
                           prefWidth="320" prefHeight="42"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d7ccc8; -fx-border-width: 1; -fx-font-size: 14px;"/>
                <Label text="Lowercase letters, numbers, underscore. Must start with a letter."
                       wrapText="true" prefWidth="320"
                       style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>

                <Label text="Password" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5d4037; -fx-padding: 4 0 0 0;"/>
                <PasswordField fx:id="passwordField" promptText="Create a strong password"
                               prefWidth="320" prefHeight="42"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d7ccc8; -fx-border-width: 1; -fx-font-size: 14px;"/>

                <Label text="Confirm password" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #5d4037; -fx-padding: 4 0 0 0;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter your password"
                               prefWidth="320" prefHeight="42"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d7ccc8; -fx-border-width: 1; -fx-font-size: 14px;"/>

                <Label text="At least 8 characters with uppercase, lowercase, a number, and a symbol (@, $, !, etc.)."
                       wrapText="true" prefWidth="320"
                       style="-fx-font-size: 11px; -fx-text-fill: #a1887f;"/>

                <Label fx:id="errorLabel" text="" wrapText="true" prefWidth="320" visible="false" managed="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #c62828; -fx-padding: 4 0 0 0;"/>

                <Button fx:id="registerButton" text="Create Account" onAction="#handleRegister"
                        prefWidth="320" prefHeight="44"
                        style="-fx-background-color: #6d4c41; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 12 0 0 0;"/>

                <HBox alignment="CENTER" spacing="4" style="-fx-padding: 8 0 0 0;">
                    <Label text="Already have an account?"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <Hyperlink text="Sign in" onAction="#openLogin"
                               style="-fx-font-size: 13px; -fx-text-fill: #6d4c41; -fx-border-color: transparent;"/>
                </HBox>

                <Hyperlink text="← Back to Home" onAction="#openHome" alignment="CENTER"
                           style="-fx-font-size: 13px; -fx-text-fill: #a1887f; -fx-padding: 6 0 0 0;"/>
            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
