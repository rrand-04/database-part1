<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.ChartController"
            style="-fx-background-color: #faf7f4;">

    <top>
        <VBox spacing="0" style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding>
                    <Insets top="14" right="28" bottom="14" left="28"/>
                </padding>
                <Button text="← Home" onAction="#backToHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Button text="Dashboard" onAction="#backToDashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: #6d4c41; -fx-cursor: hand;"/>
                <Label text="Charts &amp; Reports"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="subtitleLabel" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: #faf7f4;">
            <padding>
                <Insets top="16" right="24" bottom="24" left="24"/>
            </padding>

            <Tab text="Monthly Orders">
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16;">
                    <Label text="How many orders you placed each month"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <BarChart fx:id="monthlyOrdersChart" prefHeight="520" prefWidth="900"
                              legendVisible="false">
                        <xAxis>
                            <CategoryAxis label="Month"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Order Count"/>
                        </yAxis>
                    </BarChart>
                </VBox>
            </Tab>

            <Tab text="Spending by Category">
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16;">
                    <Label text="Total amount spent per product category"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <PieChart fx:id="spendingByCategoryChart" prefHeight="520" prefWidth="700"
                              labelsVisible="true"/>
                </VBox>
            </Tab>

            <Tab text="Order Status">
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16;">
                    <Label text="Breakdown of your orders by status"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <PieChart fx:id="orderStatusChart" prefHeight="520" prefWidth="700"
                              labelsVisible="true"/>
                </VBox>
            </Tab>

            <Tab text="Spending by Branch">
                <VBox alignment="CENTER" spacing="12" style="-fx-padding: 16;">
                    <Label text="Total amount spent at each branch"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <BarChart fx:id="spendingByBranchChart" prefHeight="480" prefWidth="900"
                              legendVisible="false">
                        <xAxis>
                            <CategoryAxis label="Branch"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Total Spent (ILS)"/>
                        </yAxis>
                    </BarChart>
                    <Label fx:id="branchSpendingTotalLabel" text=""
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                </VBox>
            </Tab>

            <Tab text="My Ratings">
                <VBox fx:id="ratingsTabContent" alignment="CENTER" spacing="12" style="-fx-padding: 16;">
                    <Label text="Your product ratings"
                           style="-fx-font-size: 13px; -fx-text-fill: #8d6e63;"/>
                    <BarChart fx:id="myRatingsChart" prefHeight="480" prefWidth="900"
                              legendVisible="false">
                        <xAxis>
                            <CategoryAxis label="Product"/>
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Rating" lowerBound="0" upperBound="5" tickUnit="1"/>
                        </yAxis>
                    </BarChart>
                    <Label fx:id="ratingsEmptyLabel" text="You haven't reviewed any products yet."
                           visible="false" managed="false" alignment="CENTER"
                           style="-fx-font-size: 15px; -fx-text-fill: #8d6e63; -fx-padding: 40;"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
