<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.vanillacoffeesystem.HomeController"
            style="-fx-background-color: #faf7f4;">

    <!-- Top bar: brand left, login/sign up right -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white; -fx-border-color: #efe6df; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="14" right="32" bottom="14" left="32"/>
            </padding>
            <Label text="Vanilla"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #5d4037;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="authBox" spacing="10" alignment="CENTER_RIGHT"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="32" alignment="TOP_CENTER">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>

                <!-- Hero -->
                <VBox alignment="CENTER" spacing="8" maxWidth="700">
                    <Label text="Fresh coffee. Sweet moments."
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #3e2723;"/>
                    <Label text="Choose your branch and explore our menu — drinks, desserts, and more."
                           wrapText="true" textAlignment="CENTER"
                           style="-fx-font-size: 15px; -fx-text-fill: #8d6e63;"/>
                </VBox>

                <!-- Category preview chips -->
                <HBox spacing="12" alignment="CENTER">
                    <Label text="🥐 Food"
                           style="-fx-background-color: #efebe9; -fx-padding: 8 16; -fx-background-radius: 20; -fx-text-fill: #5d4037;"/>
                    <Label text="☕ Drinks"
                           style="-fx-background-color: #efebe9; -fx-padding: 8 16; -fx-background-radius: 20; -fx-text-fill: #5d4037;"/>
                    <Label text="🍰 Desserts"
                           style="-fx-background-color: #efebe9; -fx-padding: 8 16; -fx-background-radius: 20; -fx-text-fill: #5d4037;"/>
                </HBox>

                <!-- Branches -->
                <VBox spacing="16" alignment="CENTER" maxWidth="900">
                    <Label text="Our Branches"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4e342e;"/>
                    <FlowPane fx:id="branchPane" hgap="20" vgap="20" alignment="CENTER"
                              prefWrapLength="860"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="24"
              style="-fx-background-color: #3e2723; -fx-padding: 16;">
            <Label text="022961179" style="-fx-text-fill: #d7ccc8; -fx-font-size: 13px;"/>
            <Label text="vanilla.ps" style="-fx-text-fill: #d7ccc8; -fx-font-size: 13px;"/>
        </HBox>
    </bottom>
</BorderPane>
